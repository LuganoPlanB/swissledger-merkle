{
  "name": "swissledger-merkle",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test clients/merkle/*.test.mjs",
    "generate:build-info": "node scripts/generate-build-info.mjs",
    "generate:vectors": "node clients/merkle/generate-vectors.mjs",
    "merkle": "node clients/merkle/merkle-cli.mjs",
    "create-merkle-root": "node clients/merkle/merkle-cli.mjs root",
    "create-merkle-proofs": "node clients/merkle/merkle-cli.mjs proofs",
